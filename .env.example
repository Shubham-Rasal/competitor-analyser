# Investor Finder environment — copy to .env and fill in values

# App
NEXT_PUBLIC_URL=https://investor-finder.vercel.app

# MongoDB
MONGODB_URI=

# OpenAI
OPENAI_API_KEY=

# x402 / Payment
PAYMENT_RECIPIENT_ADDRESS=
PAYMENT_NETWORK=base-sepolia

# Filecoin / FOC
ERC8004_AGENT_ID=           # on-chain agent token ID (from IdentityRegistry registration)
AGENT_PRIVATE_KEY=          # agent hot wallet for Filecoin Calibration txs + FOC storage
FILECOIN_CALIBRATION_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
AGENT_ECONOMY_REGISTRY_ADDRESS=   # from erc-8004-contracts/scripts/deploy-economy.ts output
DATA_LISTING_REGISTRY_ADDRESS=0xdd6c9772e4a3218f8ca7acbaeeea2ce02eb1dbf6
FOC_DRY_RUN=true            # true = mock CIDs (use until Synapse SDK M4.1 ships)

# A2A — shared secret with seo-agent (allows internal calls without x402 payment)
INTERNAL_AGENT_KEY=         # must match seo-agent's INTERNAL_AGENT_KEY
